# Copy to .env and fill in real values. NEVER commit the real .env.
# Generate a strong key with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Local dev default is SQLite; docker-compose overrides this with Postgres.
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Password for the Postgres service in docker-compose
POSTGRES_PASSWORD=devpassword
# Invite codes required to register — COMMA-SEPARATED so each customer gets their
# own (revoke one by deleting it, the rest keep working). EMPTY = sign-ups closed.
REGISTRATION_CODE=CODE-ONE,CODE-TWO,CODE-THREE
# Enables POST /ai/summarize. Empty = that endpoint returns 503.
ANTHROPIC_API_KEY=
