# Copy to .env and fill in real values. NEVER commit the real .env.
# Generate a strong key with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Local dev default is SQLite; docker-compose overrides this with Postgres.
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Password for the Postgres service in docker-compose
POSTGRES_PASSWORD=devpassword
# Invite codes required to register — COMMA-SEPARATED, seeded into the DB and then
# SINGLE-USE (each is consumed on the first successful sign-up). EMPTY = sign-ups
# closed. Give each customer their own code; a leaked code only works once.
REGISTRATION_CODE=CODE-ONE,CODE-TWO,CODE-THREE
# How many AI calls each account may make before it's cut off (trial budget).
AI_CALL_QUOTA=10
# Admin token for /admin/* (issue/revoke invite codes). EMPTY = admin API disabled.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=set-a-long-random-admin-token
# Enables POST /ai/summarize. Empty = that endpoint returns 503.
ANTHROPIC_API_KEY=
